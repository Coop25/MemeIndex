MEMEINDEX_ADDR=:8080
MEMEINDEX_DATA_DIR=data
MEMEINDEX_IMAGE=ghcr.io/your-github-user-or-org/memeindex:latest
POSTGRES_DB=memeindex
POSTGRES_USER=memeindex
POSTGRES_PASSWORD=replace-me

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# Discord OAuth
MEMEINDEX_DISCORD_CLIENT_ID=123456789012345678
MEMEINDEX_DISCORD_CLIENT_SECRET=replace-me
MEMEINDEX_DISCORD_REDIRECT_URL=http://localhost:8080/auth/callback
MEMEINDEX_DISCORD_DYNAMIC_REDIRECT=false
MEMEINDEX_SESSION_SECRET=replace-with-a-long-random-string
MEMEINDEX_SESSION_DURATION_DAYS=30
MEMEINDEX_COOKIE_SECURE=false

# Access control
MEMEINDEX_SUPER_ADMIN_USER_IDS=333333333333333333
MEMEINDEX_VIEW_USER_IDS=111111111111111111,222222222222222222
MEMEINDEX_ADD_USER_IDS=222222222222222222
